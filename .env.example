# Copy this to .env and fill in your values
# Never commit .env to version control

# Anthropic Claude API key (required for LLM enrichment)
ANTHROPIC_API_KEY=sk-ant-...

# AlienVault OTX API key (optional - enables OTX pulse collection)
OTX_API_KEY=

# VirusTotal API key (optional - for hash enrichment)
VT_API_KEY=

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Path overrides (defaults are relative to project root)
# DB_PATH=data/db/threats.db
# BRIEFINGS_DIR=data/briefings
# SIGMA_DIR=data/sigma_rules
# LOGS_DIR=logs

# LLM settings
# LLM_MODEL=claude-opus-4-6
# LLM_MAX_TOKENS=1024
# LLM_RPM=50

# HTTP settings
# HTTP_TIMEOUT=30
# HTTP_RETRIES=3
# HTTP_PROXY=http://proxy:8080
